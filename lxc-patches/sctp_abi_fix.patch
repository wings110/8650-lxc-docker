- name: 【核心手术】无痕植入 SCTP ABI 修复代码 (Python 动态探针版)
        run: |
          echo ">>> 正在使用 Python 探针精准修复 SCTP ABI..."
          cd kernel_workspace/common
          
          # 1. 使用 Python 脚本处理头文件 (100%免疫上下文冲突，智能识别一加特有 Padding)
          cat << 'EOF' > fix_sctp_abi.py
          import re
          import sys
          
          file_path = 'include/net/net_namespace.h'
          with open(file_path, 'r') as f:
              content = f.read()
          
          # 步骤 A：精准切除结构体中间的旧 sctp (防膨胀)
          content = re.sub(r'#if defined\(CONFIG_IP_SCTP\)[^\n]*\n\s*struct netns_sctp\s+sctp;\n#endif\n', '', content)
          
          # 步骤 B：寻找一加/欧加特有的强制填充位，或者标准 KABI
          matches_sock = list(re.finditer(r'struct\s+sock\s*\*\s*:\s*64\s*;', content))
          matches_kabi = list(re.finditer(r'ANDROID_KABI_RESERVE\(\d+\);', content))
          
          if matches_sock:
              last_match = matches_sock[-1]
              replacement = """
          	/* ABI Hack: SCTP Pointer (Replaced last sock padding) */
          	union {
          		struct sock * :64;
          		struct {
          #if defined(CONFIG_IP_SCTP) || defined(CONFIG_IP_SCTP_MODULE)
          			struct netns_sctp *sctp_ptr;
          #endif
          		};
          	};"""
              content = content[:last_match.start()] + replacement + content[last_match.end():]
              print("✅ 成功替换一加特有 struct sock * :64 padding!")
          elif matches_kabi:
              last_match = matches_kabi[-1]
              res_str = last_match.group(0)
              replacement = f"""
          	/* ABI Hack: SCTP Pointer (Replaced KABI Reserve) */
          	union {{
          		struct {{
          			{res_str}
          		}};
          		struct {{
          #if defined(CONFIG_IP_SCTP) || defined(CONFIG_IP_SCTP_MODULE)
          			struct netns_sctp *sctp_ptr;
          #endif
          		}};
          	}};"""
              content = content[:last_match.start()] + replacement + content[last_match.end():]
              print(f"✅ 成功替换 {res_str} padding!")
          else:
              print("⚠️ 未找到任何 padding，直接在 } __randomize_layout; 前插入！")
              idx = content.rfind('} __randomize_layout;')
              if idx != -1:
                  replacement = """
          #if defined(CONFIG_IP_SCTP) || defined(CONFIG_IP_SCTP_MODULE)
          	struct netns_sctp *sctp_ptr;
          #endif\n"""
                  content = content[:idx] + replacement + content[idx:]
          
          # 步骤 C：追加重定向宏
          content += "\n#if defined(CONFIG_IP_SCTP) || defined(CONFIG_IP_SCTP_MODULE)\n#define net_sctp(_net) (*((_net)->sctp_ptr))\n#endif\n"
          
          with open(file_path, 'w') as f:
              f.write(content)
          print("✅ 头文件动态处理完成！")
          EOF
          
          # 执行 Python 探针脚本
          python3 fix_sctp_abi.py
          
          # 2. 为 net_namespace.c 生成并应用补丁 (这段 C 代码之前验证成功过)
          echo "" | base64 -d > sctp_c.patch
          echo "" >> sctp_c.patch
          
          patch -l -p1 -F 3 < sctp_c.patch
          echo "✅ SCTP 手术全部完成！"
